# ─────────────────────────────────────────────────────────────
# Base de datos PostgreSQL (Supabase)
# Crear cuenta gratis en https://supabase.com
# Crear nuevo proyecto → Settings → Database → Connection string
# Pegar acá la URL (reemplazar YOUR-PASSWORD)
# ─────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:YOUR-PASSWORD@db.xxxxxx.supabase.co:5432/postgres"

# Solo necesario si usas connection pooling (PgBouncer)
# DIRECT_URL="postgresql://postgres:YOUR-PASSWORD@db.xxxxxx.supabase.co:5432/postgres"

# ─────────────────────────────────────────────────────────────
# Auth (NextAuth)
# IMPORTANT: en PRODUCCIÓN generar NEXTAUTH_SECRET con:
#   openssl rand -base64 32
# ─────────────────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="cambiar-en-produccion-openssl-rand-base64-32"

# ── MODO 1: Multi-tenant con DB (recomendado) ──
# No requiere configuración adicional. Los usuarios se registran
# desde la UI. Primera migración: npx tsx scripts/migrate-multitenant.ts

# ── MODO 2: Admin único por env (legacy, backward compat) ──
# ADMIN_USER="admin"
# ADMIN_PASSWORD="cambiar-esta-password"

# ── MODO 3: Desarrollo sin auth (solo fuera de producción) ──
# AUTH_DISABLED=1

# ─────────────────────────────────────────────────────────────
# Opcional: puerto del server (Vercel lo maneja automáticamente)
# ─────────────────────────────────────────────────────────────
PORT=3000

# ─────────────────────────────────────────────────────────────
# LLM Providers (groq.ts → llm-provider.ts)
# Proveedor activo por env (default: groq)
# Soportados: groq | openai | anthropic | ollama
# ─────────────────────────────────────────────────────────────
LLM_ACTIVE_PROVIDER="groq"
GROQ_API_KEY="gsk_xxxxxxxxxxxxxx"
# OPENAI_API_KEY=""
# ANTHROPIC_API_KEY=""
# OLLAMA_HOST="http://localhost:11434"

# ─────────────────────────────────────────────────────────────
# Endpoints del agente IA (protección adicional)
# Si no se configura, en desarrollo se permite acceso sin key;
# en producción es OBLIGATORIO configurarla.
# ─────────────────────────────────────────────────────────────
# AGENT_API_KEY=""

# ─────────────────────────────────────────────────────────────
# Webhooks (opcional, para workflows vía webhook público)
# ─────────────────────────────────────────────────────────────
WEBHOOK_API_KEY=""
WEBHOOK_SECRET=""

# ─────────────────────────────────────────────────────────────
# Cross-Origin (opcional, para CSRF en multi-dominio)
# Separar múltiples orígenes con coma:
# ALLOWED_ORIGINS="https://app.obracero.com,https://preview.vercel.app"
# ─────────────────────────────────────────────────────────────
# ALLOWED_ORIGINS=""

# ─────────────────────────────────────────────────────────────
# Logging (opcional)
# Valores: debug | info | warn | error (default: debug en dev, info en prod)
# ─────────────────────────────────────────────────────────────
# LOG_LEVEL="info"

# ─────────────────────────────────────────────────────────────
# Obsidian Vault — Local REST API plugin
# Conecta el agente de ObraCero con el vault de documentación.
# Requiere instalar el plugin "Local REST API" desde Community Plugins.
# Configuración → Local REST API → copiar API Key.
# ─────────────────────────────────────────────────────────────
# OBSIDIAN_API_KEY="tu-api-key-aqui"
# OBSIDIAN_BASE_URL="https://127.0.0.1:27124"
